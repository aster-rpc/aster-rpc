{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Iroh FFI Golden Event Trace",
  "description": "Golden trace format for cross-language conformance testing. Each entry represents an FFI event or action.",

  "definitions": {
    "action": {
      "type": "string",
      "enum": ["SUBMIT", "COMPLETE", "ERROR", "CANCEL", "RELEASE", "CLOSE", "POLL"]
    },
    "op_kind": {
      "type": "string",
      "enum": ["accept", "connect", "read", "write", "open_bi", "open_uni", "accept_bi", "accept_uni", "node_create", "node_close", "endpoint_create", "endpoint_close"]
    },
    "event_kind": {
      "type": "string",
      "enum": [
        "NONE", "NODE_CREATED", "NODE_CREATE_FAILED", "ENDPOINT_CREATED", "ENDPOINT_CREATE_FAILED",
        "CLOSED", "CONNECTED", "CONNECT_FAILED", "CONNECTION_ACCEPTED", "CONNECTION_CLOSED",
        "STREAM_OPENED", "STREAM_ACCEPTED", "FRAME_RECEIVED", "SEND_COMPLETED",
        "STREAM_FINISHED", "STREAM_RESET", "ERROR", "CANCELLED"
      ]
    },
    "trace_entry": {
      "type": "object",
      "required": ["seq", "action", "op_id"],
      "properties": {
        "seq": {
          "type": "integer",
          "description": "Sequence number (0-indexed)"
        },
        "relative_time_ms": {
          "type": "integer",
          "description": "Time offset from scenario start in milliseconds"
        },
        "action": {
          "$ref": "#/definitions/action"
        },
        "op_id": {
          "type": "integer",
          "description": "Operation ID (0 if not applicable)"
        },
        "user_tag": {
          "type": "integer",
          "description": "User-provided tag (optional)"
        },
        "op": {
          "$ref": "#/definitions/op_kind",
          "description": "Operation type (for SUBMIT actions)"
        },
        "handle": {
          "type": "integer",
          "description": "Handle value (for COMPLETE/CLOSE actions)"
        },
        "kind": {
          "$ref": "#/definitions/event_kind",
          "description": "Event kind (for COMPLETE/ERROR actions)"
        },
        "status": {
          "type": "integer",
          "description": "Status code (0 = OK, non-zero = error)"
        },
        "data_len": {
          "type": "integer",
          "description": "Data length (for read completions)"
        },
        "error_msg": {
          "type": "string",
          "description": "Error message (for ERROR actions)"
        }
      }
    },
    "scenario": {
      "type": "object",
      "required": ["name", "description", "entries"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Scenario name"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "entries": {
          "type": "array",
          "items": { "$ref": "#/definitions/trace_entry" }
        }
      }
    }
  },

  "type": "array",
  "items": { "$ref": "#/definitions/trace_entry" }
}
