<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs exclude filters for Aster Java FFI bindings.
    Add entries here only when the SpotBugs warning is a false positive
    specific to FFM/native interop patterns.
-->
<FindBugsFilter>

    <!--
        Known false positives for FFM/MemorySegment code:
    -->

    <!-- MS: Segment of memory is not freed on method exit (native memory managed by Arena) -->
    <Match>
        <Or>
            <Class name="com.aster.ffi.IrohLibrary"/>
            <Class name="com.aster.ffi.IrohPollThread"/>
        </Or>
        <Bug pattern="MS_SHOULD_FINALIZE"/>
    </Match>

    <!--
        IROH_EVENT allocation is intentional — Arena handles lifetime.
        These are pre-allocated or short-lived and deliberately not closed individually.
    -->
    <Match>
        <Class name="com.aster.ffi.IrohPollThread"/>
        <Bug pattern="DM_GC"/>
    </Match>

    <!--
        Cleaners are intentional for handle leak detection.
        The Cleaner warning is acceptable since these are AutoCloseable
        and explicit close() is the primary cleanup path.
    -->
    <Match>
        <Class name="com.aster.handle.IrohHandle"/>
        <Bug pattern="CN_IDIOM_NO_SUPER_CALL"/>
    </Match>

    <!--
        CompletableFuture.orTimeout is not used in our code (manual timeout handling).
        This is a general SpotBugs false positive for concurrent code.
    -->

    <!--
        SpotBugs can produce false positives with invokedynamic and MethodHandle.
        Suppress URF_UNREAD_FIELD for runtime fields that are intentionally written once.
    -->
    <Match>
        <Class name="com.aster.ffi.IrohLibrary"/>
        <Field name="runtimeHandleSegment"/>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>

    <!--
        EI_EXPOSE_REP: Returning internal MemorySegment or handle references.
        These are intentional in the FFI binding layer — callers receive native
        handles/segments that are owned and managed by the Arena. The segment
        is not cloned; callers use it within the same Arena scope.
    -->
    <Match>
        <Or>
            <Class name="com.aster.ffi.IrohLibrary"/>
            <Class name="com.aster.handle.IrohConnection"/>
            <Class name="com.aster.handle.IrohEndpoint"/>
            <Class name="com.aster.handle.IrohRuntime"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>

    <!--
        EI_EXPOSE_REP2: Storing external mutable object into field.
        The OperationRegistry is stored in IrohPollThread and used only for
        dispatching; it is not propagated to parent or exposed externally.
    -->
    <Match>
        <Class name="com.aster.ffi.IrohPollThread"/>
        <Field name="registry"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
        URF_UNREAD_FIELD: resourceId is written for Cleaner identification
        but read via toString() in debug output — not a true unused field.
        lib and tracker fields in IrohRuntime are written but not read after
        construction — acceptable given the early-stage implementation.
    -->
    <Match>
        <Or>
            <Class name="com.aster.handle.IrohHandle"/>
            <Class name="com.aster.handle.IrohRuntime"/>
        </Or>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>

    <!--
        MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR: IrohHandle constructor calls
        freeNativeKind() which is final — this is a false positive as the method
        is not overridable.
    -->
    <Match>
        <Class name="com.aster.handle.IrohHandle"/>
        <Bug pattern="MC_OVERRIDABLE_METHOD_CALL_IN_CONSTRUCTOR"/>
    </Match>

    <!--
        CT_CONSTRUCTOR_THROW: IrohRuntime constructor calls native iroh_runtime_new
        which can throw via UnsatisfiedLinkError — this is inherent to FFI and
        unavoidable.
    -->
    <Match>
        <Class name="com.aster.handle.IrohRuntime"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>

    <!--
        EI_EXPOSE_REP2: EndpointConfig setters store mutable List/byte[] directly.
        Config is typically built and frozen before use; this is acceptable.
    -->
    <Match>
        <Class name="com.aster.config.EndpointConfig"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!--
        ICAST_INTEGER_MULTIPLY_CAST_TO_LONG: int * int multiplication in size
        calculations — the cast to long is intentional. Fix: make one operand long.
    -->
    <Match>
        <Class name="com.aster.config.EndpointConfig"/>
        <Bug pattern="ICAST_INTEGER_MULTIPLY_CAST_TO_LONG"/>
    </Match>

    <!--
        EI_EXPOSE_REP / EI_EXPOSE_REP2: IrohEvent.data() returns a native memory
        segment backed by the shared Arena. This is intentional — the segment
        is only valid during event processing and the Arena manages lifetime.
    -->
    <Match>
        <Class name="com.aster.event.IrohEvent"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="com.aster.event.IrohEvent"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

</FindBugsFilter>
