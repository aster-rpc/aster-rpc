{
  "name": "@aster-rpc/aster",
  "version": "0.2.0",
  "description": "Aster RPC framework for TypeScript — P2P services with type safety, streaming, and trust",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aster-gen": "./dist/cli/gen.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vite-plugin": {
      "import": "./dist/plugins/vite.js",
      "types": "./dist/plugins/vite.d.ts"
    },
    "./webpack-plugin": {
      "import": "./dist/plugins/webpack.js",
      "types": "./dist/plugins/webpack.d.ts"
    },
    "./gen": {
      "import": "./dist/cli/gen.js",
      "types": "./dist/cli/gen.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "typedoc --options typedoc.json"
  },
  "dependencies": {
    "@apache-fory/core": "0.17.0",
    "@aster-rpc/transport": "0.2.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typedoc": "^0.28.18",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/aster-rpc/aster-rpc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aster-rpc/aster-rpc.git",
    "directory": "bindings/typescript/packages/aster"
  },
  "bugs": {
    "url": "https://github.com/aster-rpc/aster-rpc/issues"
  },
  "keywords": [
    "iroh",
    "p2p",
    "rpc",
    "quic",
    "aster",
    "streaming",
    "framework"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
