{
  "name": "@aster-rpc/aster",
  "version": "0.1.0-alpha.0",
  "description": "Aster RPC framework for TypeScript — P2P services with type safety, streaming, and trust",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@aster-rpc/transport": "0.1.0-alpha.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/aster-rpc/aster-rpc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aster-rpc/aster-rpc.git",
    "directory": "bindings/typescript/packages/aster"
  },
  "bugs": {
    "url": "https://github.com/aster-rpc/aster-rpc/issues"
  },
  "keywords": [
    "iroh",
    "p2p",
    "rpc",
    "quic",
    "aster",
    "streaming",
    "framework"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
