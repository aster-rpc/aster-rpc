{
  "name": "@aster-rpc/transport",
  "version": "0.1.0-alpha.0",
  "description": "Iroh P2P transport bindings for Aster RPC (NAPI-RS native addon)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "*.node"
  ],
  "scripts": {
    "build": "tsc",
    "build:native": "cd ../../native && napi build --release --platform",
    "typecheck": "tsc --noEmit"
  },
  "napi": {
    "binaryName": "aster-transport",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/aster"
  }
}
