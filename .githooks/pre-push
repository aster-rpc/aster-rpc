#!/usr/bin/env bash
# Pre-push hook: runs cargo fmt + clippy to prevent CI lint failures.
# Install: git config core.hooksPath .githooks

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
RESET='\033[0m'

echo "pre-push: checking aster-cli ↔ aster-rpc version compat..."
if ! python3 scripts/check-cli-compat.py; then
    echo -e "${RED}pre-push: aster-cli lower bound is stale${RESET}"
    exit 1
fi

echo "pre-push: checking Rust lint..."

# Mirrors ci.yml and ci-typescript.yml exactly -- six checks, same scope.
# Keep this list in sync with those workflows so the hook and CI agree.
FMT_CHECKS=(
    "--manifest-path bindings/python/rust/Cargo.toml"
    "-p aster-transport-napi"
)
CLIPPY_CHECKS=(
    "--manifest-path bindings/python/rust/Cargo.toml"
    "-p aster_transport_core"
    "-p aster_transport_ffi"
    "-p aster-transport-napi"
)

for args in "${FMT_CHECKS[@]}"; do
    if ! cargo fmt $args --check >/dev/null 2>&1; then
        echo -e "${RED}pre-push: cargo fmt check failed ($args)${RESET}"
        echo "  Run: cargo fmt $args"
        exit 1
    fi
done

for args in "${CLIPPY_CHECKS[@]}"; do
    if ! cargo clippy $args -- -D warnings 2>&1 | tail -1 | grep -q "Finished"; then
        echo -e "${RED}pre-push: cargo clippy failed ($args)${RESET}"
        echo "  Run: cargo clippy $args -- -D warnings"
        exit 1
    fi
done

echo -e "${GREEN}pre-push: lint OK${RESET}"
